{
  "name": "gms-frontend",
  "version": "1.0.1-SNAPSHOT",
  "scripts": {
    "ng": "ng",
    "start": "set NODE_OPTIONS=--openssl-legacy-provider && ng serve --configuration localHttp",
    "startHttps": "set NODE_OPTIONS=--openssl-legacy-provider && ng serve --configuration localHttps",
    "mockHttp": "set NODE_OPTIONS=--openssl-legacy-provider && ng serve --configuration mockHttp",
    "startUiTestFrontend": "set NODE_OPTIONS=--openssl-legacy-provider && ng serve --port 4199 --configuration mockHttp",
    "build": "ng build --output-hashing none",
    "buildLocal": "ng build --output-hashing none --configuration productionLocal",
    "startLocal": "angular-http-server dist/gms-frontend -p 4200 --baseHref gms-app --rootFile dist/gms-frontend/index.html",
    "watch": "set NODE_OPTIONS=--openssl-legacy-provider && ng build --watch --configuration development",
    "watchHttps": "set NODE_OPTIONS=--openssl-legacy-provider && ng build --watch --configuration localHttps",
    "test": "ng test --no-watch",
    "uiTest": "npx playwright test",
    "showUiReport": "npx playwright show-report",
    "clearTestCache": "jest --clearCache",
    "coverage": "npm run test --coverage --detectOpenHandles",
    "lint": "eslint --ext .ts",
    "lint:fix": "eslint --ext .ts . --fix"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.1.5",
    "@angular/cdk": "21.1.5",
    "@angular/common": "21.1.5",
    "@angular/compiler": "21.1.5",
    "@angular/core": "21.1.5",
    "@angular/forms": "21.1.5",
    "@angular/material": "21.1.5",
    "@angular/platform-browser": "21.1.5",
    "@angular/platform-browser-dynamic": "21.1.5",
    "@angular/router": "21.1.5",
    "@angular/service-worker": "21.1.5",
    "crypto-js": "^4.2.0",
    "moment": "^2.29.4",
    "randomstring": "1.3.0",
    "rxjs": "7.8.2",
    "tslib": "^2.6.2",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "21.1.4",
    "@angular/compiler-cli": "21.1.5",
    "@playwright/test": "^1.49.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.1.0",
    "@types/randomstring": "1.3.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-standard-with-typescript": "^34.0.1",
    "eslint-plugin-jest": "^23.20.0",
    "eslint-plugin-promise": "6.1.1",
    "http-proxy-middleware": "3.0.5",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "author": {
    "name": "Peter Szrnka",
    "email": "peter.szrnka@gmail.com",
    "url": "https://github.com/peter-szrnka"
  }
}
