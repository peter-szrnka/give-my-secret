{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "outDir": "./out-tsc/spec",
    "sourceMap": true,
    "allowJs": true,
    "types": [ "vitest/globals", "node" ],
    "emitDecoratorMetadata" : true,
    "strictPropertyInitialization": false,
    "typeRoots": ["./types", "node_modules/@types", "node_modules"]
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.spec.ts"
  ],
  "exclude": [
    "src/app/common/model/**"
  ]
}